---
import "@styles/global.css";

import BaseHead from "@components/BaseHead.astro";
import NavBar from "@components/Navbar.astro";

const { title, pathname, lang, theme } = Astro.props;
---

<!doctype html>
<html lang={lang}>
	<BaseHead title={title} />
	<body class="bg-surface relative flex flex-col" data-theme={theme}>
		<noscript
			class="fixed top-0 z-50 w-full border border-red-600 bg-red-400 p-3 text-center text-white"
		>
			EN: JavaScript is disabled in your browser. It will affect the website's behavior. | FR:
			Javascript est désactivé dans votre navigateur. Cela va affecter le fonctionnement du
			site.
		</noscript>
		<a
			href="#main-content"
			class="text-heading bg-surface absolute -top-20 left-5 z-50 text-2xl uppercase focus:top-5"
			data-twomi18n="skip-to-content"
		>
			Skip to content
		</a>
		<section id="main" class="noscript:mt-20">
			<NavBar pathname={pathname} theme={theme} />
			<div id="main-content">
				<slot />
			</div>
		</section>
		<script>
			console.log(
				"  _   _ _           _             _____                        _ _   \r\n | \\ | (_)         | |           |  __ \\                      | | |  \r\n |  \\| |_  ___ ___ | | __ _ ___  | |__) |___ _ __   __ _ _   _| | |_ \r\n | . ` | |/ __/ _ \\| |/ _` / __| |  _  // _ \\ '_ \\ / _` | | | | | __|\r\n | |\\  | | (_| (_) | | (_| \\__ \\ | | \\ \\  __/ | | | (_| | |_| | | |_ \r\n |_| \\_|_|\\___\\___/|_|\\__,_|___/ |_|  \\_\\___|_| |_|\\__,_|\\__,_|_|\\__|\r\n                                                                     "
			);
			console.log("Github -> www.github.com/NicolasRenault");
		</script>
	</body>
</html>
