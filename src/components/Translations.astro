		},
		fr: {
			"navbar.homepage": "Acceuil",
			"navbar.about-me": "Qui suis-je",
			"navbar.contact": "Contact",
			copied: "Copié",
			error: "Erreur",
			"homepage-1":
				"Je suis un Développeur FullStack basé en France. Je cherche toujours à optimiser mon quotidien sous tous ses aspects, c'est pourquoi j'aime créer des applications qui aident les gens à accomplir leurs tâches plus rapidement et plus efficacement.",
			"homepage-2":
				"En dehors de la programmation, j'aime faire du sport comme le gravel et le volley-ball, passer du temps avec ma",
			"homepage-3": "et mes amis, et jouer aux jeux vidéo.",
			girlfriend: "copine",
			"work-current-job": "Emploi actuel",
			"trelleborg-1":
				"Dans l'entreprise depuis 2021, j'ai eu l'opportunité d'évoluer au sein de différentes organisations. J'ai commencé en tant que Développeur d'Applications, principalement concentré sur la création d'interfaces logicielle et l'extension des fonctionnalités de notre ERP.",
			"trelleborg-2":
				"Suite à une réorganisation de l'IT, j'ai rejoint le pôle Innovation Digitale. Ma mission : analyser les processus de 52 sites différents pour déployer des solutions à l'échelle du groupe.",
			"trelleborg-3":
				"Aujourd'hui, je me concentre davantage sur la Gestion de Projet et la Business Analysis, avec une vision claire pour la suite de ma carrière.",
			projects: "Projets",
			"projects-headline":
				"Voici une liste de mes projets personnels. La plupart sont en Open Source. N'hésitez pas à y jeter un œil sur mon",
			"this-project-is-fork": "Ce projet est un fork de",
			"find-project": "Retrouvez le projet ici",
			"see-on-github": "Voir sur GitHub",
			"see-original": "Voir le projet original",
			"school-projects": "Projets scolaire",
		},
	};

	const twoMi18n = new TwoMi18n(translations);

	const buttonEN = document.getElementById("translation-button-en");
	const buttonFR = document.getElementById("translation-button-fr");

	buttonEN?.addEventListener("click", () => {
		handleTanslation("en");
	});
	buttonFR?.addEventListener("click", () => {
		handleTanslation("fr");
	});

	/**
	 * Handle all the changes needed for the translations
	 *  - Lang selector
	 *  - Add ?lang={lang} to URL Parameters
	 *  - Call TwoMi18n function
	 *
	 * @param lang
	 */
	function handleTanslation(lang) {
		if (lang === "en") {
			buttonEN.setAttribute("disabled", true);
			buttonFR.removeAttribute("disabled");

			window.history.replaceState("lang", null, "?lang=en");
		} else if (lang === "fr") {
			buttonEN.removeAttribute("disabled");
			buttonFR.setAttribute("disabled", true);

			window.history.replaceState("lang", null, "?lang=fr");
		}

		//Set <html> lang (Used as a signal for translation for other javascript tags)
		document.documentElement.lang = lang;

		changeLinkLangParam(lang);
		twoMi18n.translateHTML(lang);
	}

	/**
	 * Check in the URL if the {lang} param exist.
	 * If so, call @handleTranslation
	 */
	function getLangFromURL() {
		const params = new URLSearchParams(document.location.search);

		if (params.size !== 0) {
			const lang = params.get("lang");
			if (lang in translations) handleTanslation(lang);
		}
	}

	/**
	 * Change the href of all link in the page that have data-link.
	 * This is used for link that navigate the different pages, not the external links.
	 *
	 * @param lang
	 */
	function changeLinkLangParam(lang) {
		const anchors = document.querySelectorAll<HTMLAnchorElement>("[data-link]");

		anchors.forEach((anchor) => {
			let url = new URL(anchor.href);
			let params = new URLSearchParams(url.search);

			url.searchParams.set("lang", lang);

			anchor.href = url.toString();
		});
	}

	// TODO remove comment to enable back this on log (off for dev purose) getLangFromURL(); //Triggered once on load
</script>
