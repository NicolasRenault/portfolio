---
import { redirectTargets, type RedirectTargets } from "@data/footer-redirect-map";

const { origin, theme } = Astro.props;

let redirect = false;
let target = "";
let text_EN = "";
let text_FR = "";

if (origin) {
	if (origin in redirectTargets) {
		redirect = true;
		target = (redirectTargets as RedirectTargets)[origin].target;
		text_EN = (redirectTargets as RedirectTargets)[origin].text_EN;
		text_FR = (redirectTargets as RedirectTargets)[origin].text_FR;
	}
}
---

<footer
	id="page-footer"
	class:list={[{ navigate: redirect }]}
	data-enable-redirect={redirect}
	data-target={target}
>
	<section class="section-wrapper" data-theme={theme}>
		<div class="relative flex h-400 flex-col items-center justify-center gap-12 pt-50 pb-0">
			<nr-logo size="xl" rainbow style="color: var(--color-heading)"></nr-logo>
			{
				redirect && (
					<div
						id="sticky-container"
						class="relative bottom-0 flex h-full items-center text-2xl"
					>
						<a
							id="sticky"
							href="#bottom"
							title="Bottom page"
							data-twomi18n="bottom-page[title]"
							class="sticky bottom-[40%] flex flex-col content-center items-center"
						>
							<p class="show-en text-heading mb-5">{text_EN}</p>
							<p class="show-fr text-heading mb-5">{text_FR}</p>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								viewBox="0 0 24 24"
								class="text-heading h-11"
							>
								<path
									fill="currentColor"
									d="M11 4h2v12l5.5-5.5l1.42 1.42L12 19.84l-7.92-7.92L5.5 10.5L11 16z"
								/>
							</svg>
						</a>
					</div>
				)
			}
			<div id="bottom"></div>
		</div>
	</section>
</footer>

<script is:inline>
	const footer = document.querySelector("#page-footer");
	const enableRedirection = footer?.getAttribute("data-enable-redirect") !== null;
	const target = footer?.getAttribute("data-target");

	document.addEventListener("scroll", () => {
		if (
			enableRedirection &&
			window.innerHeight + window.scrollY >= document.body.offsetHeight - 50
		) {
			// document.body.classList.add("navigateOnScroll");

			setTimeout(() => {
				window.location.href = target;
				console.log("OK");
			}, 500);
		}
	});
</script>
