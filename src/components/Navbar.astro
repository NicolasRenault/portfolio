---
import Translations from "@components/Translations.astro";

const {pathname} = Astro.props;
---

<nav id="navbar" class="flex fixed w-full bottom-0 left-0 z-50 justify-between mx-auto p-3 bg-surface border-t-2 border-border/60 md:relative md:p-5 md:bg-transparent md:border-x md:max-w-[calc(100vw-2rem)] md:min-[90rem]:max-w-360 md:border-b md:border-t-0 md:border-border/20">
    <div class="hidden md:block mr-0">
        <a href="/" class="flex w-fit">
            <nr-logo size="md" color='light' animated class="hover:-translate-y-0.5 transition-transform"></nr-logo>
        </a>
    </div>
    <div class="flex flex-row-reverse w-full gap-5 text-lg mr-0 justify-between font-extrabold text-heading uppercase md:flex-row md:w-auto md:text-2xl max-[400px]:text-sm">
        <ul class="flex flex-row-reverse h-full items-center gap-3 list-none md:flex-row md:gap-5">
            <li>
                <a href="#" data-twomi18n="homepage" class:list={["link-animation", {active: pathname == "homepage"}]}>Homepage</a>
            </li>
            <li>
                <a href="#" data-twomi18n="about-me" class:list={["link-animation", {active: pathname == "about-me"}]}>About Me</a>
            </li>
            <li>
                <a href="#" data-twomi18n="contact" class:list={["link-animation", {active: pathname == "contact"}]}>Contact</a>
            </li>
        </ul>
        <div class="flex flex-row-reverse gap-3 items-center md:flex-row md:gap-5 ">
            <a href="#" class="hover:-translate-y-0.5">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" class="w-5 h-5 md:w-7 md:h-7 max-[400px]:w-4 max-[400px]:h-4"><path fill="currentColor" d="M6 0a6 6 0 1 1 0 12A6 6 0 0 1 6 0m0 .98C3.243.98 1 3.223 1 6a5.02 5.02 0 0 0 3.437 4.77l.045.005c.203.01.279-.129.279-.25l-.007-.854c-1.39.303-1.684-.674-1.684-.674c-.227-.58-.555-.734-.555-.734c-.454-.312.034-.306.034-.306c.365.026.604.288.708.43l.058.088c.446.767 1.17.546 1.455.418c.046-.325.174-.546.317-.672c-1.11-.127-2.277-.558-2.277-2.482c0-.548.195-.996.515-1.348l-.03-.085c-.064-.203-.152-.658.079-1.244l.04-.007c.124-.016.548-.013 1.335.522A4.8 4.8 0 0 1 6 3.408c.425.002.853.058 1.252.17c.955-.65 1.374-.516 1.374-.516c.272.692.1 1.202.05 1.33c.32.35.513.799.513 1.347c0 1.93-1.169 2.354-2.283 2.478c.18.155.34.462.34.93l-.006 1.378c0 .13.085.282.323.245A5.02 5.02 0 0 0 11 6C11 3.223 8.757.98 6 .98"/></svg>
            </a>
            <Translations/>
        </div>
    </div>
</nav>

<style>
    @reference "../styles/global.css";

    body {
        /* Margin bottom for NavBar on mobile devices */
        @apply mb-13.5 md:mb-0 
    }
</style>